@{
    Layout = null;
}
<!DOCTYPE html>
<html ng-app="internshipApp">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Internship Project</title>

    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">

    <script src="https://code.angularjs.org/1.4.8/angular.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/angular-ui-bootstrap/0.14.3/ui-bootstrap-tpls.min.js"></script>

    <script src="~/Scripts/app/app.js"></script>
    <script src="~/Scripts/app/services/apiService.js"></script>

    <script src="~/Scripts/app/directives/clientTypeSelector.js"></script>
    <script src="~/Scripts/app/directives/deviceSelector.js"></script>
    <script src="~/Scripts/app/directives/clientSelector.js"></script>
    <script src="~/Scripts/app/directives/phoneNumberSelector.js"></script>

    <script src="~/Scripts/app/controllers/devicesController.js"></script>
    <script src="~/Scripts/app/Controllers/clientsController.js"></script>
    <script src="~/Scripts/app/Controllers/phoneNumbersController.js"></script>
    <script src="~/Scripts/app/Controllers/phoneNumberReservationsController.js"></script>
    <script src="~/Scripts/app/Controllers/reportsController.js"></script>
    <script src="~/Scripts/app/Controllers/loginController.js"></script>
    <script src="~/Scripts/app/Controllers/registerController.js"></script>

</head>

<body ng-controller="mainController">

    <div style="padding: 20px;">
        <h1 style="color: #333; border-bottom: 2px solid #ccc; padding-bottom: 10px;">
            Management System
        </h1>
        <!-- Navigation Bar -->
        <div class="toolbar" ng-show="isLoggedIn" style="background: #e9ecef; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
            <div class="btn-group" role="group" style="margin-right: 20px;">
                <button type="button" class="btn btn-primary" ng-click="navigate('/Templates/devices.html')">Devices</button>
                <button type="button" class="btn btn-prim
                        ary" ng-click="navigate('/Templates/clients.html')">Clients</button>
                <button type="button" class="btn btn-primary" ng-click="navigate('/Templates/phoneNumbers.html')">Phone Numbers</button>
                <button type="button" class="btn btn-info" ng-click="navigate('/Templates/phoneNumberReservations.html')">Reservations History</button>
                <!-- Reports Group -->
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-success" ng-click="navigate('/Templates/reportClientsPerType.html')">Clients Report</button>
                    <button type="button" class="btn btn-success" ng-click="navigate('/Templates/reportPhoneStatus.html')">Phone Status Report</button>
                </div>
                <div class="pull-right">
                    <span style="margin-right: 15px;">Welcome, <strong>{{loggedInUser}}</strong>!</span>
                    <button class="btn btn-sm btn-danger" ng-click="logout()"><i class="glyphicon glyphicon-log-out"></i> Logout</button>
                </div>
            </div>

        </div>

        <div ng-include="currentView"></div>
    </div>

</body>

</html>